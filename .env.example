# Google Workspace — SMTP autenticado
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_ENCRYPTION=tls
SMTP_USERNAME=contato@trafoengenharia.com.br
SMTP_PASSWORD=COLE_AQUI_A_SENHA_DE_APP_SEM_ESPACOS

# Remetente precisa, normalmente, pertencer ao mesmo domínio autenticado
MAIL_FROM=contato@trafoengenharia.com.br
MAIL_FROM_NAME=Site Trafo Engenharia
MAIL_TO=contato@trafoengenharia.com.br
MAIL_TO_NAME=Trafo Engenharia

# Origens públicas autorizadas, separadas por vírgula e sem barra no final
ALLOWED_ORIGINS=https://www.trafoengenharia.com.br,https://trafoengenharia.com.br

# Painel privado de estatísticas — gere o hash e o salt com o comando indicado no guia
ANALYTICS_ENABLED=true
ANALYTICS_USERNAME=admin
ANALYTICS_PASSWORD_HASH=
ANALYTICS_SALT=
ANALYTICS_RETENTION_DAYS=90
ANALYTICS_TIMEZONE=America/Sao_Paulo
ANALYTICS_DATA_DIR=backend/data
GEOIP_DATABASE=backend/data/GeoLite2-City.mmdb

# Ative somente se o domínio estiver realmente atrás do proxy da Cloudflare
TRUST_CLOUDFLARE=false
